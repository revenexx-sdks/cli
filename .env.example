# Revenexx CLI configuration
#
# Copy this file to `.env` and fill in the values below.
#
# Credential resolution order (per DX-22):
#   1. CLI flags (`--token`, `--endpoint`, `--project-id`)
#   2. Environment variables (this file, after `dotenv` loads it)
#   3. Project file `.revenexx.yaml` (nearest one, walking up from CWD)
#   4. Global config at `~/.revenexx/config.json` (set by `revenexx login`)

# API base URL. Override only for self-hosted or staging instances.
REVENEXX_API_URL=https://api.revenexx.com/v1

REVENEXX_API_KEY=

# Tenant slug for the API gateway (X-Revenexx-Tenant); doubles as the
# project ID. `revenexx tenants use <slug>` also persists one.
REVENEXX_TENANT=
